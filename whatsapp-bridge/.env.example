# Server settings
PORT=3001
HOST=0.0.0.0

# Botty API settings
BOTTY_API_URL=http://localhost:5001
BOTTY_API_KEY=

# WhatsApp settings
SESSION_PATH=./.wwebjs_auth
HEADLESS=true

# Logging
LOG_LEVEL=info

# WebSocket heartbeat (ms)
WS_HEARTBEAT_INTERVAL=30000

# Auto-create Kanban tasks for incoming messages
AUTO_CREATE_TASKS=true

# Restrict to specific contacts (comma-separated phone numbers or names)
# Leave empty to allow all contacts
ALLOWED_CONTACTS=
