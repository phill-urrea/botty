    "@types/ws": "^8.5.12",
    "@types/uuid": "^10.0.0",
    "@types/node": "^22.7.5",
    "typescript": "^5.6.3",
    "tsx": "^4.19.1",
    "eslint": "^9.12.0",
    "@typescript-eslint/parser": "^8.8.1",
