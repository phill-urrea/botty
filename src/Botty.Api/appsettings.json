{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Botty": "Debug"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "https://bot.phill.ie"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=botty;Username=botty;Password=botty_dev_password"
  },
  "OAuth": {
    "Providers": {
      "Google": {
        "ClientId": "",
        "ClientSecret": "",
        "RedirectUri": "http://localhost:5001/api/oauth/providers/google/callback",
        "Scopes": [
          "openid",
          "email",
          "profile",
          "https://www.googleapis.com/auth/gmail.readonly",
          "https://www.googleapis.com/auth/gmail.send",
          "https://www.googleapis.com/auth/gmail.modify",
          "https://www.googleapis.com/auth/calendar",
          "https://www.googleapis.com/auth/calendar.events"
        ]
      }
    }
  },
  "WhatsAppBridge": {
    "BaseUrl": "http://localhost:3001"
  },
  "GCP": {
    "ProjectId": ""
  },
  "Memory": {
    "MinimumScoreThreshold": 0.4,
    "MaxMemoriesPerConversation": 5
  },
  "Embedding": {
    "Provider": "auto",
    "Fallback": "placeholder",
    "Model": "",
    "ApiKey": ""
  },
  "Claude": {
    "ApiKey": "",
    "DefaultModel": "claude-sonnet-4-20250514",
    "DefaultMaxTokens": 4096
  },
  "Soul": {
    "FilePath": "config/Soul.md"
  },
  "Conversation": {
    "MemoryExtractionMinTurns": 3,
    "MaxMemoryTokens": 500,
    "DefaultModel": "claude-sonnet-4-20250514",
    "DefaultMaxTokens": 4096,
    "DefaultTemperature": 0.7,
    "DefaultAdminUserId": "00000000-0000-0000-0000-000000000001"
  },
  "Channels": {
    "WhatsApp": {
      "Enabled": false,
      "BridgeUrl": "http://localhost:3001",
      "TimeoutSeconds": 30,
      "AutoReconnect": true,
      "HealthCheckIntervalSeconds": 60,
      "ChunkLimit": 4000,
      "ChunkMode": "length",
      "DefaultAccount": "default",
      "Security": {
        "GroupPolicy": "open",
        "DmPolicy": "open",
        "AllowFrom": [],
        "Groups": {}
      },
      "Accounts": {}
    }
  }
}
