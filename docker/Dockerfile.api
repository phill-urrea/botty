# Build stage
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Copy solution and project files
COPY Botty.slnx ./
COPY src/Botty.Core/Botty.Core.csproj src/Botty.Core/
COPY src/Botty.Hooks/Botty.Hooks.csproj src/Botty.Hooks/
COPY src/Botty.Secrets/Botty.Secrets.csproj src/Botty.Secrets/
COPY src/Botty.Memory/Botty.Memory.csproj src/Botty.Memory/
COPY src/Botty.LLM/Botty.LLM.csproj src/Botty.LLM/
COPY src/Botty.Tools/Botty.Tools.csproj src/Botty.Tools/
COPY src/Botty.Messaging/Botty.Messaging.csproj src/Botty.Messaging/
COPY src/Botty.Workflow/Botty.Workflow.csproj src/Botty.Workflow/
COPY src/Botty.Scheduler/Botty.Scheduler.csproj src/Botty.Scheduler/
COPY src/Botty.Infrastructure/Botty.Infrastructure.csproj src/Botty.Infrastructure/
COPY src/Botty.Channels/Botty.Channels.csproj src/Botty.Channels/
COPY src/Botty.Cli/Botty.Cli.csproj src/Botty.Cli/
COPY src/Botty.Api/Botty.Api.csproj src/Botty.Api/

# Restore only the API project (skips test projects not in the image)
RUN dotnet restore src/Botty.Api/Botty.Api.csproj

# Copy source code
COPY src/ src/

# Build and publish
WORKDIR /src/src/Botty.Api
RUN dotnet publish -c Release -o /app/publish
RUN dotnet tool install --tool-path /playwright-tools Microsoft.Playwright.CLI
RUN /playwright-tools/playwright install chromium

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app

# Copy published app
COPY --from=build /app/publish .
COPY --from=build /playwright-tools /playwright-tools
COPY --from=build /root/.cache/ms-playwright /root/.cache/ms-playwright

# Install runtimes for script execution
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip nodejs npm \
    libglib2.0-0t64 libnss3 libnspr4 libdbus-1-3 libatk1.0-0t64 \
    libatk-bridge2.0-0t64 libcups2t64 libx11-6 libxcomposite1 libxdamage1 \
    libxext6 libxfixes3 libxrandr2 libgbm1 libdrm2 libxcb1 libxkbcommon0 \
    libpango-1.0-0 libcairo2 libasound2t64 libatspi2.0-0t64 \
    && rm -rf /var/lib/apt/lists/*

# Create config, workspace, and local secrets directories
RUN mkdir -p /app/config /app/workspace/scripts /app/secrets

# Set environment variables
ENV ASPNETCORE_URLS=http://+:8080
ENV ASPNETCORE_ENVIRONMENT=Production

EXPOSE 8080

ENTRYPOINT ["dotnet", "Botty.Api.dll"]
